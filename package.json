{
  "name": "rednote-auth-service",
  "version": "1.0.0",
  "description": "JWT-based authentication microservice for Rednote social media platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:local:reset": "rm -rf test/fixtures/pg-dev-data && node scripts/dev-local.mjs",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/auth.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "keys:generate": "bash scripts/generate-keys.sh",
    "docs:generate": "node scripts/generate-openapi.mjs"
  },
  "keywords": [
    "auth",
    "jwt",
    "fastify",
    "microservice"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/env": "^5.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/client": "^6.9.0",
    "argon2": "^0.43.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "embedded-postgres": "^18.4.0-beta.17",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
