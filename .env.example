# Server
NODE_ENV=development
PORT=3001

# PostgreSQL
# 5433 = embedded Postgres (dev:local). 5432 = docker compose / system Postgres.
DATABASE_URL=postgresql://auth:auth@localhost:5433/auth_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT RS256 key paths (generate with: npm run keys:generate)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Token TTLs (seconds)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Blacklist behavior when Redis is unavailable: "open" | "closed"
REDIS_BLACKLIST_FAIL_MODE=closed

# Enable Swagger UI in production (enabled by default in development)
DOCS_ENABLED=true
